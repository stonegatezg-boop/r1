// © Mix1_ADX_Cla v2.3 - Converted from MQL5 EA
// Based on @gu5tavo71 TradingView Indicator
// Created: 2026-03-11

//@version=5
indicator("Mix1 EMA Cross + Trend Channel + ADX/DI", shorttitle="Mix1_ADX", overlay=true)

// ═══════════════════════════════════════════════════════════════════
// INPUT PARAMETERS
// ═══════════════════════════════════════════════════════════════════

// EMA Cross Settings
grp1 = "═══ EMA CROSS POSTAVKE ═══"
emaFastLen = input.int(26, "EMA Fast Period", minval=1, group=grp1)
emaMedLen = input.int(50, "EMA Medium Period", minval=1, group=grp1)

// Trend Channel Settings
grp2 = "═══ TREND CHANNEL POSTAVKE ═══"
maTrendLen = input.int(200, "MA Trend Period", minval=1, group=grp2)
useSMA = input.bool(true, "Use SMA (false = EMA)", group=grp2)
channelATRMult = input.float(0.618, "ATR Multiplier for Channel", minval=0.1, step=0.1, group=grp2)
atrPeriod = input.int(14, "ATR Period", minval=1, group=grp2)

// ADX/DI Settings
grp3 = "═══ ADX/DI POSTAVKE ═══"
adxPeriod = input.int(14, "ADX Period", minval=1, group=grp3)
adxThreshold = input.int(22, "ADX Threshold (Strong Trend)", minval=1, group=grp3)
diBuffer = input.float(10.0, "DI Buffer %", minval=0, step=1, group=grp3)

// Signal Confirmation
grp4 = "═══ SIGNAL POTVRDA ═══"
requireCandleConf = input.bool(true, "Require Bull/Bear Candle", group=grp4)
requireADXConf = input.bool(true, "Require ADX Confirmation", group=grp4)

// Display Settings
grp5 = "═══ DISPLAY POSTAVKE ═══"
showEMAs = input.bool(true, "Show EMAs", group=grp5)
showChannel = input.bool(true, "Show Trend Channel", group=grp5)
showSignals = input.bool(true, "Show BUY/SELL Signals", group=grp5)
showBackground = input.bool(true, "Show Trend Background", group=grp5)

// ═══════════════════════════════════════════════════════════════════
// INDICATOR CALCULATIONS
// ═══════════════════════════════════════════════════════════════════

// EMAs
emaFast = ta.ema(close, emaFastLen)
emaMed = ta.ema(close, emaMedLen)

// MA Trend (SMA or EMA based on setting)
maTrend = useSMA ? ta.sma(close, maTrendLen) : ta.ema(close, maTrendLen)

// ATR for channel
atr = ta.atr(atrPeriod)

// Trend Channel
channelTop = maTrend + atr * channelATRMult
channelBot = maTrend - atr * channelATRMult

// ADX/DI Calculation (using built-in)
[diPlus, diMinus, adx] = ta.dmi(adxPeriod, adxPeriod)

// ═══════════════════════════════════════════════════════════════════
// TREND DIRECTION CALCULATION (Mix1 Strategy 2 Logic)
// ═══════════════════════════════════════════════════════════════════

// MA Direction: Fast EMA vs Medium EMA
maDir = emaFast > emaMed ? 1 : -1

// Trend Direction: Price vs MA Trend
maTrendDir = close >= maTrend ? 1 : -1

// Check if price is inside channel (range/neutral zone)
inChannel = (open <= channelTop or close <= channelTop) and (open >= channelBot or close >= channelBot)

// Final Trend Direction
// If in channel -> neutral (0)
// If maTrendDir == 1 AND maDir == 1 -> bullish (1)
// If maTrendDir == -1 AND maDir == -1 -> bearish (-1)
getTrendDir() =>
    if inChannel
        0
    else if maTrendDir == 1 and maDir == 1
        1
    else if maTrendDir == -1 and maDir == -1
        -1
    else
        0

trendDir = getTrendDir()

// ═══════════════════════════════════════════════════════════════════
// ADX/DI HISTOGRAM SIGNAL
// ═══════════════════════════════════════════════════════════════════

// Calculate DI histogram (similar to Pine Script reference)
// Bullish: DI+ > DI- + (DI+ * buffer%)
// Bearish: DI- > DI+ + (DI- * buffer%)

bufferPlus = diPlus * diBuffer / 100.0
bufferMinus = diMinus * diBuffer / 100.0

bullishDI = diPlus > (diMinus + bufferPlus)
bearishDI = diMinus > (diPlus + bufferMinus)

// ADX Signal
// Strong bullish: DI+ > DI- with buffer AND ADX > threshold
// Strong bearish: DI- > DI+ with buffer AND ADX > threshold
// Weak signals: ADX between 11-25
getADXSignal() =>
    if bullishDI and adx > adxThreshold
        1
    else if bearishDI and adx > adxThreshold
        -1
    else if bullishDI and adx > 11
        1
    else if bearishDI and adx > 11
        -1
    else
        0

adxSignal = getADXSignal()

// ═══════════════════════════════════════════════════════════════════
// CANDLE CONFIRMATION
// ═══════════════════════════════════════════════════════════════════

isBullishCandle = close > open
isBearishCandle = close < open

// ═══════════════════════════════════════════════════════════════════
// SIGNAL GENERATION
// ═══════════════════════════════════════════════════════════════════

// BUY Conditions:
// 1. Trend direction is bullish
// 2. ADX/DI confirms bullish momentum (optional)
// 3. Bullish candle (optional)
adxConfBuy = not requireADXConf or adxSignal == 1
candleConfBuy = not requireCandleConf or isBullishCandle
buySignal = trendDir == 1 and adxConfBuy and candleConfBuy

// SELL Conditions:
// 1. Trend direction is bearish
// 2. ADX/DI confirms bearish momentum (optional)
// 3. Bearish candle (optional)
adxConfSell = not requireADXConf or adxSignal == -1
candleConfSell = not requireCandleConf or isBearishCandle
sellSignal = trendDir == -1 and adxConfSell and candleConfSell

// ═══════════════════════════════════════════════════════════════════
// PLOTTING
// ═══════════════════════════════════════════════════════════════════

// EMAs
plot(showEMAs ? emaFast : na, "EMA Fast", color=color.new(color.blue, 0), linewidth=2)
plot(showEMAs ? emaMed : na, "EMA Medium", color=color.new(color.orange, 0), linewidth=2)

// MA Trend and Channel
plot(showChannel ? maTrend : na, "MA Trend 200", color=color.new(color.gray, 0), linewidth=2)
p1 = plot(showChannel ? channelTop : na, "Channel Top", color=color.new(color.green, 60))
p2 = plot(showChannel ? channelBot : na, "Channel Bot", color=color.new(color.red, 60))
fill(p1, p2, color=showChannel ? color.new(color.gray, 90) : na, title="Channel Fill")

// Background color based on trend
bgColor = trendDir == 1 ? color.new(color.green, 90) : trendDir == -1 ? color.new(color.red, 90) : na
bgcolor(showBackground ? bgColor : na, title="Trend Background")

// BUY/SELL Signals
plotshape(showSignals and buySignal and not buySignal[1], "BUY Signal",
          style=shape.triangleup, location=location.belowbar,
          color=color.green, size=size.normal, text="BUY")

plotshape(showSignals and sellSignal and not sellSignal[1], "SELL Signal",
          style=shape.triangledown, location=location.abovebar,
          color=color.red, size=size.normal, text="SELL")

// ═══════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════

alertcondition(buySignal and not buySignal[1], "Mix1 BUY Signal",
               "Mix1_ADX: BUY Signal - TrendDir={{trendDir}} ADX={{adx}}")

alertcondition(sellSignal and not sellSignal[1], "Mix1 SELL Signal",
               "Mix1_ADX: SELL Signal - TrendDir={{trendDir}} ADX={{adx}}")

// ═══════════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════════

var table infoTable = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "Mix1 ADX/DI", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "", text_color=color.white, text_size=size.small)

    trendText = trendDir == 1 ? "BULLISH" : trendDir == -1 ? "BEARISH" : "NEUTRAL"
    trendColor = trendDir == 1 ? color.green : trendDir == -1 ? color.red : color.gray
    table.cell(infoTable, 0, 1, "Trend:", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, trendText, text_color=trendColor, text_size=size.small)

    table.cell(infoTable, 0, 2, "ADX:", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(adx, "#.#"), text_color=adx > adxThreshold ? color.green : color.gray, text_size=size.small)

    table.cell(infoTable, 0, 3, "DI+:", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(diPlus, "#.#"), text_color=diPlus > diMinus ? color.green : color.gray, text_size=size.small)

    table.cell(infoTable, 0, 4, "DI-:", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 4, str.tostring(diMinus, "#.#"), text_color=diMinus > diPlus ? color.red : color.gray, text_size=size.small)

    table.cell(infoTable, 0, 5, "EMA Cross:", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 5, maDir == 1 ? "BULL" : "BEAR", text_color=maDir == 1 ? color.green : color.red, text_size=size.small)

    table.cell(infoTable, 0, 6, "In Channel:", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 6, inChannel ? "YES" : "NO", text_color=inChannel ? color.yellow : color.gray, text_size=size.small)
