//@version=5
indicator("OHLCV History Table", overlay=true)

// ============================================
// SETTINGS
// ============================================
showTable    = input.bool(true, "Show Table")
tableRows    = input.int(100, "Number of Rows", minval=10, maxval=500)
tablePosition = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"])

// Colors
headerBg     = input.color(color.rgb(33, 115, 70), "Header Background")
headerText   = input.color(color.white, "Header Text")
row1Bg       = input.color(color.rgb(220, 230, 241), "Row Color 1 (Light)")
row2Bg       = input.color(color.rgb(189, 215, 238), "Row Color 2 (Dark)")
daySeparator = input.color(color.rgb(0, 0, 0), "Day Separator Color")
textColor    = input.color(color.rgb(0, 0, 0), "Text Color")

// ============================================
// TABLE SETUP
// ============================================
var tablePos = tablePosition == "Top Right" ? position.top_right :
               tablePosition == "Top Left" ? position.top_left :
               tablePosition == "Bottom Right" ? position.bottom_right : position.bottom_left

var table dataTable = table.new(tablePos, 9, tableRows + 1, border_width=1, border_color=color.gray)

// ============================================
// HELPER FUNCTIONS
// ============================================
getDateStr(t) => str.format("{0,date,yyyy.MM.dd}", t)

formatVol(v) =>
    if v >= 1000000
        str.tostring(v / 1000000, "#.##") + "M"
    else if v >= 1000
        str.tostring(v / 1000, "#.##") + "K"
    else
        str.tostring(v, "#")

// ============================================
// MAIN TABLE LOGIC
// ============================================
if barstate.islast and showTable

    // === HEADER ROW ===
    table.cell(dataTable, 0, 0, "Date",     bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 1, 0, "Time",     bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 2, 0, "Open",     bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 3, 0, "High",     bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 4, 0, "Low",      bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 5, 0, "Close",    bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 6, 0, "Change",   bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 7, 0, "Change%",  bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)
    table.cell(dataTable, 8, 0, "Volume",   bgcolor=headerBg, text_color=headerText, text_size=size.small, text_halign=text.align_center)

    // === DATA ROWS ===
    string prevDate = ""
    int colorToggle = 0

    for i = 1 to tableRows
        if bar_index >= i
            // Get current row date
            string currentDate = getDateStr(time[i])

            // Check if day changed - toggle color group
            bool newDay = currentDate != prevDate and prevDate != ""
            if newDay
                colorToggle := colorToggle == 0 ? 1 : 0

            // Alternate colors within day group + different shade for different days
            color rowBg = na
            if colorToggle == 0
                rowBg := i % 2 == 0 ? row1Bg : row2Bg
            else
                rowBg := i % 2 == 0 ? color.rgb(255, 242, 204) : color.rgb(255, 230, 153)  // Yellow tones for alternate days

            // Add black separator line for new day
            if newDay
                rowBg := daySeparator

            // Calculate values
            float chgVal = close[i] - close[i+1]
            float chgPct = close[i+1] != 0 ? (chgVal / close[i+1]) * 100 : 0

            // Value colors
            color closeClr = close[i] > open[i] ? color.rgb(0, 128, 0) : color.rgb(192, 0, 0)
            color chgClr = chgVal >= 0 ? color.rgb(0, 128, 0) : color.rgb(192, 0, 0)

            // Text color for separator row
            color txtClr = newDay ? color.white : textColor

            // Date cell - only show if new day or first row
            string dateDisplay = (newDay or i == 1) ? currentDate : ""

            // Fill cells
            table.cell(dataTable, 0, i, dateDisplay, bgcolor=rowBg, text_color=txtClr, text_size=size.tiny, text_halign=text.align_left)
            table.cell(dataTable, 1, i, str.format("{0,time,HH:mm}", time[i]), bgcolor=rowBg, text_color=txtClr, text_size=size.tiny, text_halign=text.align_center)
            table.cell(dataTable, 2, i, str.tostring(open[i], format.mintick), bgcolor=rowBg, text_color=txtClr, text_size=size.tiny, text_halign=text.align_right)
            table.cell(dataTable, 3, i, str.tostring(high[i], format.mintick), bgcolor=rowBg, text_color=newDay ? color.white : color.rgb(0, 128, 0), text_size=size.tiny, text_halign=text.align_right)
            table.cell(dataTable, 4, i, str.tostring(low[i], format.mintick), bgcolor=rowBg, text_color=newDay ? color.white : color.rgb(192, 0, 0), text_size=size.tiny, text_halign=text.align_right)
            table.cell(dataTable, 5, i, str.tostring(close[i], format.mintick), bgcolor=rowBg, text_color=newDay ? color.white : closeClr, text_size=size.tiny, text_halign=text.align_right)

            string chgSign = chgVal >= 0 ? "+" : ""
            table.cell(dataTable, 6, i, chgSign + str.tostring(chgVal, format.mintick), bgcolor=rowBg, text_color=newDay ? color.white : chgClr, text_size=size.tiny, text_halign=text.align_right)
            table.cell(dataTable, 7, i, chgSign + str.tostring(chgPct, "#.##") + "%", bgcolor=rowBg, text_color=newDay ? color.white : chgClr, text_size=size.tiny, text_halign=text.align_right)
            table.cell(dataTable, 8, i, formatVol(volume[i]), bgcolor=rowBg, text_color=txtClr, text_size=size.tiny, text_halign=text.align_right)

            prevDate := currentDate
